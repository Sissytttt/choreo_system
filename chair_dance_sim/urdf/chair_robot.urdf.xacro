<?xml version="1.0"?>
<!--
  Dancing Chair Robot — URDF (xacro)

  Physical design:
    A foldable metal chair with two powered wheels attached to the back legs.
    Front legs rest on small caster spheres for stability.

  Kinematics: Differential drive (two back wheels)

  Coordinate frame:
    x = forward (towards front legs)
    z = up
    Origin at center of seat underside

  Key dimensions (meters):
    Seat:     0.40 wide × 0.40 deep × 0.02 thick
    Backrest: 0.40 wide × 0.35 tall × 0.02 thick, tilted 10° back
    Legs:     0.025 radius × 0.45 long (steel tube)
    Wheels:   0.075 radius × 0.03 wide
    Track:    0.45 m (center-to-center of back wheels)
-->
<robot name="chair_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ══════════════════════════════════════════════════════════════════════
       Parameters
       ══════════════════════════════════════════════════════════════════════ -->
  <xacro:property name="seat_w"       value="0.40"/>
  <xacro:property name="seat_d"       value="0.40"/>
  <xacro:property name="seat_t"       value="0.02"/>
  <xacro:property name="seat_height"  value="0.45"/>

  <xacro:property name="back_w"       value="0.40"/>
  <xacro:property name="back_h"       value="0.35"/>
  <xacro:property name="back_t"       value="0.02"/>
  <xacro:property name="back_tilt"    value="${-10.0 * 3.14159 / 180.0}"/>

  <xacro:property name="leg_r"        value="0.025"/>
  <xacro:property name="leg_len"      value="${seat_height}"/>

  <xacro:property name="wheel_r"      value="0.075"/>
  <xacro:property name="wheel_w"      value="0.03"/>
  <xacro:property name="track"        value="0.45"/>

  <xacro:property name="caster_r"     value="0.02"/>

  <!-- Mass (kg) -->
  <xacro:property name="seat_mass"    value="2.0"/>
  <xacro:property name="back_mass"    value="1.5"/>
  <xacro:property name="leg_mass"     value="0.3"/>
  <xacro:property name="wheel_mass"   value="0.5"/>
  <xacro:property name="caster_mass"  value="0.1"/>

  <!-- Colors -->
  <xacro:property name="chair_color"  value="0.15 0.15 0.15 1.0"/>
  <xacro:property name="wheel_color"  value="0.3 0.3 0.3 1.0"/>
  <xacro:property name="caster_color" value="0.5 0.5 0.5 1.0"/>

  <!-- ══════════════════════════════════════════════════════════════════════
       Macros
       ══════════════════════════════════════════════════════════════════════ -->

  <!-- Box inertia -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
             iyy="${m*(x*x+z*z)/12}" iyz="0"
             izz="${m*(x*x+y*y)/12}"/>
  </xacro:macro>

  <!-- Cylinder inertia (along z-axis) -->
  <xacro:macro name="cyl_inertia" params="m r h">
    <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
             iyy="${m*(3*r*r+h*h)/12}" iyz="0"
             izz="${m*r*r/2}"/>
  </xacro:macro>

  <!-- Sphere inertia -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0"
             iyy="${2*m*r*r/5}" iyz="0"
             izz="${2*m*r*r/5}"/>
  </xacro:macro>

  <!-- Chair leg macro -->
  <xacro:macro name="chair_leg" params="name x y">
    <link name="${name}_leg">
      <visual>
        <geometry><cylinder radius="${leg_r}" length="${leg_len}"/></geometry>
        <material name="chair_mat"><color rgba="${chair_color}"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${leg_r}" length="${leg_len}"/></geometry>
      </collision>
      <inertial>
        <mass value="${leg_mass}"/>
        <xacro:cyl_inertia m="${leg_mass}" r="${leg_r}" h="${leg_len}"/>
      </inertial>
    </link>
    <joint name="${name}_leg_joint" type="fixed">
      <parent link="seat"/>
      <child  link="${name}_leg"/>
      <origin xyz="${x} ${y} ${-leg_len/2}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- Wheel macro (continuous joint for differential drive) -->
  <xacro:macro name="drive_wheel" params="name y_sign">
    <link name="${name}_wheel">
      <visual>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="wheel_mat"><color rgba="${wheel_color}"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <xacro:cyl_inertia m="${wheel_mass}" r="${wheel_r}" h="${wheel_w}"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${name}_leg"/>
      <child  link="${name}_wheel"/>
      <!-- Wheel sits at bottom of back leg, offset outward -->
      <origin xyz="0 ${y_sign * (leg_r + wheel_w/2 + 0.005)} ${-leg_len/2}"
              rpy="${-1.5708} 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.1" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- Caster macro (frictionless sphere at bottom of front leg) -->
  <xacro:macro name="caster" params="name parent_leg">
    <link name="${name}_caster">
      <visual>
        <geometry><sphere radius="${caster_r}"/></geometry>
        <material name="caster_mat"><color rgba="${caster_color}"/></material>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_r}"/></geometry>
        <surface>
          <friction>
            <ode><mu>0.001</mu><mu2>0.001</mu2></ode>
          </friction>
        </surface>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <xacro:sphere_inertia m="${caster_mass}" r="${caster_r}"/>
      </inertial>
    </link>
    <joint name="${name}_caster_joint" type="fixed">
      <parent link="${parent_leg}_leg"/>
      <child  link="${name}_caster"/>
      <origin xyz="0 0 ${-leg_len/2 - caster_r + 0.005}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>


  <!-- ══════════════════════════════════════════════════════════════════════
       Robot Structure
       ══════════════════════════════════════════════════════════════════════ -->

  <!-- base_footprint: on the ground plane, used by nav -->
  <link name="base_footprint"/>

  <!-- base_link: at wheel axle height -->
  <link name="base_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_r}" rpy="0 0 0"/>
  </joint>

  <!-- ── Seat ─────────────────────────────────────────────────────────── -->
  <link name="seat">
    <visual>
      <geometry><box size="${seat_d} ${seat_w} ${seat_t}"/></geometry>
      <material name="chair_mat"><color rgba="${chair_color}"/></material>
    </visual>
    <collision>
      <geometry><box size="${seat_d} ${seat_w} ${seat_t}"/></geometry>
    </collision>
    <inertial>
      <mass value="${seat_mass}"/>
      <xacro:box_inertia m="${seat_mass}" x="${seat_d}" y="${seat_w}" z="${seat_t}"/>
    </inertial>
  </link>

  <joint name="seat_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="seat"/>
    <!-- Seat is above the wheel axle. Back legs are at the rear of the seat. -->
    <origin xyz="${seat_d/4} 0 ${seat_height - wheel_r + seat_t/2}" rpy="0 0 0"/>
  </joint>

  <!-- ── Backrest ─────────────────────────────────────────────────────── -->
  <link name="backrest">
    <visual>
      <geometry><box size="${back_t} ${back_w} ${back_h}"/></geometry>
      <material name="chair_mat"><color rgba="${chair_color}"/></material>
    </visual>
    <collision>
      <geometry><box size="${back_t} ${back_w} ${back_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="${back_mass}"/>
      <xacro:box_inertia m="${back_mass}" x="${back_t}" y="${back_w}" z="${back_h}"/>
    </inertial>
  </link>

  <joint name="backrest_joint" type="fixed">
    <parent link="seat"/>
    <child  link="backrest"/>
    <!-- Backrest rises from the back edge of the seat, tilted slightly back -->
    <origin xyz="${-seat_d/2 + back_t/2} 0 ${seat_t/2 + back_h/2}"
            rpy="0 ${back_tilt} 0"/>
  </joint>

  <!-- ── Back legs (with drive wheels) ────────────────────────────────── -->
  <xacro:chair_leg name="back_left"  x="${-seat_d/2 + leg_r}" y="${ seat_w/2 - leg_r}"/>
  <xacro:chair_leg name="back_right" x="${-seat_d/2 + leg_r}" y="${-seat_w/2 + leg_r}"/>

  <xacro:drive_wheel name="back_left"  y_sign="1"/>
  <xacro:drive_wheel name="back_right" y_sign="-1"/>

  <!-- ── Front legs (with casters) ────────────────────────────────────── -->
  <xacro:chair_leg name="front_left"  x="${ seat_d/2 - leg_r}" y="${ seat_w/2 - leg_r}"/>
  <xacro:chair_leg name="front_right" x="${ seat_d/2 - leg_r}" y="${-seat_w/2 + leg_r}"/>

  <xacro:caster name="front_left"  parent_leg="front_left"/>
  <xacro:caster name="front_right" parent_leg="front_right"/>


  <!-- ══════════════════════════════════════════════════════════════════════
       Gz Sim (Fortress) Plugins
       ══════════════════════════════════════════════════════════════════════ -->

  <gazebo>
    <!-- Differential drive controller (Gz Sim system plugin) -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>back_left_wheel_joint</left_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <wheel_separation>${track}</wheel_separation>
      <wheel_radius>${wheel_r}</wheel_radius>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <!-- Joint state publisher for RViz -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>back_left_wheel_joint</joint_name>
      <joint_name>back_right_wheel_joint</joint_name>
      <update_rate>50</update_rate>
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- Wheel surface properties for good traction -->
  <gazebo reference="back_left_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>
  <gazebo reference="back_right_wheel">
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <!-- Low friction on casters -->
  <gazebo reference="front_left_caster">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
  </gazebo>
  <gazebo reference="front_right_caster">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
  </gazebo>

</robot>
