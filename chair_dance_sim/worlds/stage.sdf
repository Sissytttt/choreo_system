<?xml version="1.0" ?>
<!--
  Dance Stage — Gz Sim (Fortress) World

  A performance stage environment for the dancing chair robot:
  - Wooden stage floor (elevated platform)
  - Stage lighting (directional + colored spots)
  - Curtain backdrop (walls)
  - Audience area markers
-->
<sdf version="1.7">
  <world name="dance_stage">

    <!-- Gz Sim required system plugins -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>

    <!-- ── Physics ──────────────────────────────────────────────────────── -->
    <physics name="default_physics" type="ode">
      <max_step_size>0.002</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>500</real_time_update_rate>
    </physics>

    <!-- ── Lighting ─────────────────────────────────────────────────────── -->

    <!-- Main overhead (warm stage light) -->
    <light type="directional" name="stage_overhead">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 8 0 0 0</pose>
      <diffuse>1.0 0.95 0.85 1</diffuse>
      <specular>0.5 0.48 0.42 1</specular>
      <direction>0.0 0.0 -1.0</direction>
      <attenuation>
        <range>30</range>
        <constant>0.3</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Stage left spot (warm amber) -->
    <light type="spot" name="spot_left">
      <pose>-3 3 5 0 0.6 -0.5</pose>
      <diffuse>1.0 0.7 0.3 1</diffuse>
      <specular>0.5 0.35 0.15 1</specular>
      <direction>0.3 -0.3 -1.0</direction>
      <attenuation>
        <range>15</range>
        <constant>0.1</constant>
        <linear>0.05</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <spot>
        <inner_angle>0.5</inner_angle>
        <outer_angle>1.0</outer_angle>
        <falloff>1.0</falloff>
      </spot>
    </light>

    <!-- Stage right spot (cool blue) -->
    <light type="spot" name="spot_right">
      <pose>-3 -3 5 0 0.6 0.5</pose>
      <diffuse>0.4 0.6 1.0 1</diffuse>
      <specular>0.2 0.3 0.5 1</specular>
      <direction>0.3 0.3 -1.0</direction>
      <attenuation>
        <range>15</range>
        <constant>0.1</constant>
        <linear>0.05</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <spot>
        <inner_angle>0.5</inner_angle>
        <outer_angle>1.0</outer_angle>
        <falloff>1.0</falloff>
      </spot>
    </light>

    <!-- Ambient fill -->
    <light type="directional" name="ambient_fill">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.15 0.15 0.2 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <direction>0 0 -1</direction>
    </light>

    <!-- ── Ground plane (beneath the stage) ─────────────────────────────── -->
    <model name="ground_plane">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>50 50</size></plane>
          </geometry>
          <material>
            <ambient>0.05 0.05 0.08 1</ambient>
            <diffuse>0.08 0.08 0.12 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── Stage platform (raised wooden floor) ─────────────────────────── -->
    <model name="stage_floor">
      <static>true</static>
      <pose>0 0 0.0 0 0 0</pose>
      <link name="stage_link">
        <!-- Main stage surface -->
        <collision name="stage_collision">
          <geometry>
            <box><size>6.0 8.0 0.005</size></box>
          </geometry>
          <surface>
            <friction>
              <ode><mu>0.8</mu><mu2>0.8</mu2></ode>
            </friction>
          </surface>
        </collision>
        <visual name="stage_visual">
          <geometry>
            <box><size>6.0 8.0 0.005</size></box>
          </geometry>
          <material>
            <ambient>0.35 0.22 0.10 1</ambient>
            <diffuse>0.55 0.35 0.18 1</diffuse>
            <specular>0.15 0.12 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ── Backdrop curtain (back wall) ─────────────────────────────────── -->
    <model name="backdrop">
      <static>true</static>
      <pose>-3.1 0 1.5 0 0 0</pose>
      <link name="backdrop_link">
        <visual name="backdrop_visual">
          <geometry>
            <box><size>0.05 8.0 3.0</size></box>
          </geometry>
          <material>
            <ambient>0.05 0.02 0.02 1</ambient>
            <diffuse>0.15 0.02 0.02 1</diffuse>
          </material>
        </visual>
        <collision name="backdrop_collision">
          <geometry>
            <box><size>0.05 8.0 3.0</size></box>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- ── Side curtains ────────────────────────────────────────────────── -->
    <model name="curtain_left">
      <static>true</static>
      <pose>-1.0 4.05 1.5 0 0 0</pose>
      <link name="curtain_link">
        <visual name="curtain_visual">
          <geometry><box><size>4.5 0.05 3.0</size></box></geometry>
          <material>
            <ambient>0.05 0.02 0.02 1</ambient>
            <diffuse>0.15 0.02 0.02 1</diffuse>
          </material>
        </visual>
        <collision name="curtain_collision">
          <geometry><box><size>4.5 0.05 3.0</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="curtain_right">
      <static>true</static>
      <pose>-1.0 -4.05 1.5 0 0 0</pose>
      <link name="curtain_link">
        <visual name="curtain_visual">
          <geometry><box><size>4.5 0.05 3.0</size></box></geometry>
          <material>
            <ambient>0.05 0.02 0.02 1</ambient>
            <diffuse>0.15 0.02 0.02 1</diffuse>
          </material>
        </visual>
        <collision name="curtain_collision">
          <geometry><box><size>4.5 0.05 3.0</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ── Stage edge markers (tape lines, like real dance stages) ────── -->
    <model name="center_mark">
      <static>true</static>
      <pose>0 0 0.006 0 0 0</pose>
      <link name="mark_link">
        <visual name="mark_visual">
          <geometry><box><size>0.05 0.05 0.001</size></box></geometry>
          <material>
            <ambient>0.8 0.8 0.2 1</ambient>
            <diffuse>1.0 1.0 0.3 1</diffuse>
            <emissive>0.3 0.3 0.1 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- Downstage edge markers (audience-facing, 5 small marks) -->
    <model name="ds_mark_1"><static>true</static>
      <pose>2.9 -3.0 0.006 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.02 0.001</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>1 1 1 1</diffuse><emissive>0.2 0.2 0.2 1</emissive></material>
      </visual></link>
    </model>
    <model name="ds_mark_2"><static>true</static>
      <pose>2.9 -1.5 0.006 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.02 0.001</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>1 1 1 1</diffuse><emissive>0.2 0.2 0.2 1</emissive></material>
      </visual></link>
    </model>
    <model name="ds_mark_3"><static>true</static>
      <pose>2.9 0.0 0.006 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.02 0.001</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>1 1 1 1</diffuse><emissive>0.2 0.2 0.2 1</emissive></material>
      </visual></link>
    </model>
    <model name="ds_mark_4"><static>true</static>
      <pose>2.9 1.5 0.006 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.02 0.001</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>1 1 1 1</diffuse><emissive>0.2 0.2 0.2 1</emissive></material>
      </visual></link>
    </model>
    <model name="ds_mark_5"><static>true</static>
      <pose>2.9 3.0 0.006 0 0 0</pose>
      <link name="l"><visual name="v"><geometry><box><size>0.3 0.02 0.001</size></box></geometry>
        <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>1 1 1 1</diffuse><emissive>0.2 0.2 0.2 1</emissive></material>
      </visual></link>
    </model>

    <!-- ── Chair Robot (embedded to avoid spawn/gz-transport issues) ─────── -->
    <model name='chair_robot'>
      <pose>0 0 0.01 0 0 0</pose>
      <link name='base_footprint'>
        <inertial>
          <pose>0.04887983706720979 0 0.4418024439918533 0 0 0</pose>
          <mass>4.91</mass>
          <inertia>
            <ixx>0.281118</ixx><ixy>0</ixy><ixz>0.075792</ixz>
            <iyy>0.303047</iyy><iyz>0</iyz><izz>0.202419</izz>
          </inertia>
        </inertial>
        <collision name='seat_col'><pose>0.1 0 0.46 0 0 0</pose><geometry><box><size>0.4 0.4 0.02</size></box></geometry></collision>
        <collision name='bl_leg_col'><pose>-0.075 0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry></collision>
        <collision name='br_leg_col'><pose>-0.075 -0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry></collision>
        <collision name='back_col'><pose>-0.09 0 0.645 0 -0.1745 0</pose><geometry><box><size>0.02 0.4 0.35</size></box></geometry></collision>
        <collision name='fl_leg_col'><pose>0.275 0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry></collision>
        <collision name='fl_cast_col'><pose>0.275 0.175 -0.005 0 0 0</pose><geometry><sphere><radius>0.02</radius></sphere></geometry><surface><friction><ode><mu>0.001</mu><mu2>0.001</mu2></ode></friction></surface></collision>
        <collision name='fr_leg_col'><pose>0.275 -0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry></collision>
        <collision name='fr_cast_col'><pose>0.275 -0.175 -0.005 0 0 0</pose><geometry><sphere><radius>0.02</radius></sphere></geometry><surface><friction><ode><mu>0.001</mu><mu2>0.001</mu2></ode></friction></surface></collision>
        <visual name='seat_vis'><pose>0.1 0 0.46 0 0 0</pose><geometry><box><size>0.4 0.4 0.02</size></box></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='bl_leg_vis'><pose>-0.075 0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='br_leg_vis'><pose>-0.075 -0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='back_vis'><pose>-0.09 0 0.645 0 -0.1745 0</pose><geometry><box><size>0.02 0.4 0.35</size></box></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='fl_leg_vis'><pose>0.275 0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='fl_cast_vis'><pose>0.275 0.175 -0.005 0 0 0</pose><geometry><sphere><radius>0.02</radius></sphere></geometry><material><diffuse>0.5 0.5 0.5 1</diffuse><ambient>0.5 0.5 0.5 1</ambient></material></visual>
        <visual name='fr_leg_vis'><pose>0.275 -0.175 0.235 0 0 0</pose><geometry><cylinder><length>0.45</length><radius>0.025</radius></cylinder></geometry><material><diffuse>0.15 0.15 0.15 1</diffuse><ambient>0.15 0.15 0.15 1</ambient></material></visual>
        <visual name='fr_cast_vis'><pose>0.275 -0.175 -0.005 0 0 0</pose><geometry><sphere><radius>0.02</radius></sphere></geometry><material><diffuse>0.5 0.5 0.5 1</diffuse><ambient>0.5 0.5 0.5 1</ambient></material></visual>
      </link>
      <joint name='back_left_wheel_joint' type='revolute'>
        <pose relative_to='base_footprint'>-0.075 0.22 0.01 -1.5708 0 0</pose>
        <parent>base_footprint</parent><child>back_left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.1</damping><friction>0.05</friction></dynamics></axis>
      </joint>
      <link name='back_left_wheel'>
        <pose relative_to='back_left_wheel_joint'>0 0 0 0 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.000741</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000741</iyy><iyz>0</iyz><izz>0.001406</izz></inertia></inertial>
        <collision name='blw_col'><geometry><cylinder><length>0.03</length><radius>0.075</radius></cylinder></geometry><surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface></collision>
        <visual name='blw_vis'><geometry><cylinder><length>0.03</length><radius>0.075</radius></cylinder></geometry><material><diffuse>0.3 0.3 0.3 1</diffuse><ambient>0.3 0.3 0.3 1</ambient></material></visual>
      </link>
      <joint name='back_right_wheel_joint' type='revolute'>
        <pose relative_to='base_footprint'>-0.075 -0.22 0.01 -1.5708 0 0</pose>
        <parent>base_footprint</parent><child>back_right_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit><dynamics><damping>0.1</damping><friction>0.05</friction></dynamics></axis>
      </joint>
      <link name='back_right_wheel'>
        <pose relative_to='back_right_wheel_joint'>0 0 0 0 0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.000741</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000741</iyy><iyz>0</iyz><izz>0.001406</izz></inertia></inertial>
        <collision name='brw_col'><geometry><cylinder><length>0.03</length><radius>0.075</radius></cylinder></geometry><surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface></collision>
        <visual name='brw_vis'><geometry><cylinder><length>0.03</length><radius>0.075</radius></cylinder></geometry><material><diffuse>0.3 0.3 0.3 1</diffuse><ambient>0.3 0.3 0.3 1</ambient></material></visual>
      </link>
      <plugin name='gz::sim::systems::DiffDrive' filename='gz-sim-diff-drive-system'>
        <left_joint>back_left_wheel_joint</left_joint>
        <right_joint>back_right_wheel_joint</right_joint>
        <wheel_separation>0.45</wheel_separation>
        <wheel_radius>0.075</wheel_radius>
        <max_linear_acceleration>2.0</max_linear_acceleration>
        <odom_publish_frequency>50</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
      </plugin>
      <plugin name='gz::sim::systems::JointStatePublisher' filename='gz-sim-joint-state-publisher-system'>
        <joint_name>back_left_wheel_joint</joint_name>
        <joint_name>back_right_wheel_joint</joint_name>
        <update_rate>50</update_rate>
        <topic>joint_states</topic>
      </plugin>
    </model>

  </world>
</sdf>
